{
  "name": "my-better-t-app",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "lucide-react": "^0.546.0",
      "next": "^16.2.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "@trpc/server": "^11.13.4",
      "@trpc/client": "^11.13.4",
      "better-auth": "1.5.5",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18",
      "drizzle-orm": "^0.45.1",
      "@types/pg": "^8.16.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "check-types": "bun run --filter '*' check-types",
    "dev:web": "bun run --filter web dev",
    "db:push": "bun run --filter @my-better-t-app/db db:push",
    "db:studio": "bun run --filter @my-better-t-app/db db:studio",
    "db:generate": "bun run --filter @my-better-t-app/db db:generate",
    "db:migrate": "bun run --filter @my-better-t-app/db db:migrate",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@my-better-t-app/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@my-better-t-app/config": "workspace:*",
    "@types/node": "^22.13.14",
    "typescript": "^5",
    "ultracite": "7.4.0"
  },
  "packageManager": "bun@1.3.0"
}